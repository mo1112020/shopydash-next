{
  "ci": {
    "collect": {
      "url": ["http://localhost:3000/"],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-setuid-sandbox --disable-gpu --disable-dev-shm-usage"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
